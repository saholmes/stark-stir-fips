==================================================================
RUNBOOK — six bench invocations covering the full Table 5 sweep
==================================================================

The CPU-heavy work happens once per (hash variant, extension field)
combination — that's three builds for {SHA3-256, SHA3-384, SHA3-512}
at Fp⁶ plus one build for SHA3-512 at Fp⁸. Within each build, the env
vars BENCH_R and BENCH_CSV_OUT select level + filename per run.

Each command produces both presets (binary-arity baseline + 4x4x4 STIR)
in one CSV — the row's `label` column distinguishes them. The k column
selects LDE size: for T=2^16 binary, blowup 32 → k=21; for T=2^16
arity-4, blowup 32 → k=22 (because d_c=2 ⇒ |H_0| = 2·T·blowup = 2^22).
The bench's blowup sweep covers k=11..25 so both are captured.

------------------------------------------------------------------
# Build 1: SHA3-256, Fp⁶ — L1 q=2^40
cd "/Volumes/SAHexternal 1/Documents/stark-stir-fips/stark-stir-fips-security"
BENCH_R=54 \
  BENCH_CSV_OUT="Final-NIST-L1-k4arity-SHA256-FP6-r54-q2-40-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
    --no-default-features --features parallel,sha3-256

# Build 2: SHA3-384, Fp⁶ — L1 q=2^65 (r=54) AND L3 q=2^40 (r=79).
# Two runs, same build:
BENCH_R=54 \
  BENCH_CSV_OUT="Final-NIST-L1-k4arity-SHA3384-FP6-r54-q2-65-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
    --no-default-features --features parallel,sha3-384

BENCH_R=79 \
  BENCH_CSV_OUT="Final-NIST-L3-k4arity-SHA384-FP6-r79-q2-40-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
    --no-default-features --features parallel,sha3-384

# Build 3: SHA3-512, Fp⁶ — L1 q=2^90 (r=54) AND L3 q=2^90 (r=79).
BENCH_R=54 \
  BENCH_CSV_OUT="Final-NIST-L1-k4arity-SHA3512-FP6-r54-q2-90-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
    --no-default-features --features parallel,sha3-512

BENCH_R=79 \
  BENCH_CSV_OUT="Final-NIST-L3-k4arity-SHA512-FP6-r79-q2-90-q2-65-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
    --no-default-features --features parallel,sha3-512

# Build 4: SHA3-512, Fp⁸ — L5 q=2^40 (r=105).
BENCH_R=105 \
  BENCH_CSV_OUT="Final-NIST-L5-k4arity-SHA512-FP8-r105-multiair-benchmarkdata.csv" \
  cargo bench -p channel --bench end_to_end \
